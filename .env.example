# ============================================================
# EdgeAuth — Environment Variables
# Copy to .env and fill in your values before running.
# ============================================================

# --- Local Device Server (ai_engine/server.py) ---
WVP_DB_PATH=workforce_verification.db          # SQLite database file path
WVP_EMBEDDING_KEY=your-secret-key-here         # AES encryption key for face embeddings
                                                # If not set, falls back to hostname-based key

# --- AWS Sync Engine (backend/local_device/sync_engine.py) ---
WVP_AWS_API_ENDPOINT=https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/prod/sync
WVP_API_KEY=your-aws-api-gateway-key           # x-api-key header for API Gateway
WVP_DEVICE_ID=device-hostname                  # Defaults to socket.gethostname()
WVP_SYNC_INTERVAL=30                           # Seconds between sync cycles
WVP_BATCH_SIZE=50                              # Max logs per sync batch
WVP_MAX_ATTEMPTS=10                            # Max retry attempts per log

# --- S3 Model Distribution ---
WVP_S3_MODELS_BUCKET=wvp-models
WVP_S3_MODELS_PREFIX=face-embedding-models/
WVP_LOCAL_MODELS_DIR=./models
WVP_MODEL_SYNC_ENABLED=true
WVP_MODEL_SYNC_INTERVAL=3600                   # Seconds between S3 model checks (default 1hr)

# --- AWS Credentials (for local_device sync and S3 model sync) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=ap-south-1

# --- AWS SAM Deployment (backend/aws_serverless) ---
# These match samconfig.toml — only change if deploying to a different region/stack
# sam build && sam deploy
