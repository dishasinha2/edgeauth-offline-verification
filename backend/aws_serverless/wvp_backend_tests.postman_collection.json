        },

        {
          "name": "GET /employees/{id} — Fetch Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has employee object', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('employee');",
                  "    pm.expect(body.employee).to.have.property('employee_id');",
                  "    pm.expect(body.employee).to.have.property('face_embedding');",
                  "    pm.expect(body.employee.face_embedding).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Embedding is deserialized as array', function () {",
                  "    const emb = pm.response.json().employee.face_embedding;",
                  "    pm.expect(emb.length).to.be.oneOf([128, 256, 512]);",
                  "});",
                  "",
                  "pm.test('Response time under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method":      "GET",
            "description": "Fetch full worker metadata including deserialized face_embedding vector, embedding model name, S3 photo key, and all registration fields.",
            "header": [
              { "key": "x-api-key", "value": "{{API_KEY}}" }
            ],
            "url": {
              "raw":      "{{BASE_URL}}/employees/{{EMPLOYEE_ID}}",
              "host":     ["{{BASE_URL}}"],
              "path":     ["employees", "{{EMPLOYEE_ID}}"],
              "variable": [
                {
                  "key":         "id",
                  "value":       "{{EMPLOYEE_ID}}",
                  "description": "Employee UUID — auto-populated from POST /employees."
                }
              ]
            }
          },
          "response": [
            {
              "name":   "200 OK — Employee found",
              "status": "OK",
