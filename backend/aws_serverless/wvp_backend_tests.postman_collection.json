{
  "info": {
    "_postman_id": "wvp-backend-collection-v1",
    "name": "Workforce Verification Platform — Full API",
    "description": "Complete Postman test collection for the Offline-First Workforce Verification Platform.\n\nCovers all REST endpoints exposed via AWS API Gateway:\n  • POST   /sync                     — Batch edge-device log sync\n  • POST   /organizations            — Register a company workspace\n  • GET    /organizations/{id}       — Fetch workspace metadata + liveness thresholds\n  • POST   /employees                — Register employee + upload face photo to S3\n  • GET    /employees/{id}           — Fetch worker metadata\n  • PUT    /employees/{id}/embedding — Update face embedding weights\n\nUsage:\n  1. Import this file into Postman.\n  2. Set the collection variable 'BASE_URL' to your deployed API Gateway base URL.\n     Example: https://abc123def4.execute-api.ap-south-1.amazonaws.com/prod\n  3. Optionally set 'API_KEY' if EnableApiKey=true in your SAM deployment.\n  4. Run requests individually or use the Collection Runner for full suite testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/prod",
      "description": "Base URL of your deployed API Gateway. Replace with the 'ApiBaseUrl' SAM output value.",
      "type": "string"
    },
    {
      "key": "API_KEY",
      "value": "YOUR_API_KEY_HERE",
      "description": "API Gateway API Key (x-api-key header). Leave blank if EnableApiKey=false.",
      "type": "string"
    },
    {
      "key": "ORG_ID",
      "value": "00000000-0000-0000-0000-000000000001",
      "description": "Auto-populated after running 'Register Organization'. Used in subsequent requests.",
      "type": "string"
    },
    {
      "key": "EMPLOYEE_ID",
      "value": "00000000-0000-0000-0000-000000000002",
      "description": "Auto-populated after running 'Register Employee'. Used in subsequent requests.",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key":   "key",
        "value": "x-api-key",
        "type":  "string"
      },
      {
        "key":   "value",
        "value": "{{API_KEY}}",
        "type":  "string"
      },
      {
        "key":   "in",
        "value": "header",
        "type":  "string"
      }
    ]
  },
  "item": [

    {
      "name": "1. Organizations",
      "description": "Endpoints for managing company workspace (organization) records.",
      "item": [

        {
          "name": "POST /organizations — Register Organization",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has organization_id', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('organization_id');",
                  "    pm.expect(body.organization_id).to.be.a('string');",
                  "    // Auto-populate collection variable for downstream requests",
                  "    pm.collectionVariables.set('ORG_ID', body.organization_id);",
                  "    console.log('ORG_ID set to:', body.organization_id);",
                  "});",
                  "",
                  "pm.test('Status field is created', function () {",
                  "    pm.expect(pm.response.json().status).to.equal('created');",
                  "});",
                  "",
                  "pm.test('liveness_threshold is present', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('liveness_threshold');",
                  "    pm.expect(body.liveness_threshold).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Response time under 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method":      "POST",
            "description": "Register a new company workspace (organization). The liveness_threshold field controls the minimum face liveness confidence score required for this org's employees to clock in.",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key",    "value": "{{API_KEY}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nexus Construction Group\",\n  \"region\": \"APAC\",\n  \"contact_email\": \"admin@nexusconstruction.com\",\n  \"liveness_threshold\": 0.82\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw":      "{{BASE_URL}}/organizations",
              "host":     ["{{BASE_URL}}"],
              "path":     ["organizations"],
              "variable": []
            }
          },
          "response": [
            {
              "name":   "201 Created — Organization registered successfully",
              "status": "Created",
              "code":   201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"created\",\n  \"organization_id\": \"b890760f-b758-46f1-96bb-516588ad8c21\",\n  \"name\": \"Nexus Construction Group\",\n  \"region\": \"APAC\",\n  \"liveness_threshold\": 0.82,\n  \"created_at\": \"2024-01-15T08:00:00+00:00\",\n  \"request_id\": \"abc123\"\n}"
            },
            {
              "name":   "409 Conflict — Organization already exists",
              "status": "Conflict",
              "code":   409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"conflict\",\n  \"error\": \"Organization 'b890760f-...' already exists.\",\n  \"request_id\": \"def456\"\n}"
            },
            {
              "name":   "422 Unprocessable — Missing required field",
              "status": "Unprocessable Entity",
              "code":   422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"error\",\n  \"error\": \"'name' is required.\",\n  \"request_id\": \"ghi789\"\n}"
            }
          ]
        },

        {
          "name": "GET /organizations/{id} — Fetch Organization",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has organization object', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('organization');",
                  "    pm.expect(body.organization).to.have.property('organization_id');",
                  "    pm.expect(body.organization).to.have.property('liveness_threshold');",
                  "});",
                  "",
                  "pm.test('Status field is ok', function () {",
                  "    pm.expect(pm.response.json().status).to.equal('ok');",
                  "});",
                  "",
                  "pm.test('Response time under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method":      "GET",
            "description": "Retrieve workspace metadata including the organization's adaptive liveness_threshold. Edge devices use this value to decide whether to grant or deny access for borderline liveness scores.",
            "header": [
              { "key": "x-api-key", "value": "{{API_KEY}}" }
            ],
            "url": {
              "raw":      "{{BASE_URL}}/organizations/{{ORG_ID}}",
              "host":     ["{{BASE_URL}}"],
              "path":     ["organizations", "{{ORG_ID}}"],
              "variable": [
                {
                  "key":         "id",
                  "value":       "{{ORG_ID}}",
                  "description": "Organization UUID — auto-populated from POST /organizations."
                }
              ]
            }
          },
          "response": [
            {
              "name":   "200 OK — Organization found",
              "status": "OK",
              "code":   200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"ok\",\n  \"organization\": {\n    \"organization_id\": \"b890760f-b758-46f1-96bb-516588ad8c21\",\n    \"name\": \"Nexus Construction Group\",\n    \"region\": \"APAC\",\n    \"contact_email\": \"admin@nexusconstruction.com\",\n    \"is_active\": true,\n    \"liveness_threshold\": 0.82,\n    \"created_at\": \"2024-01-15T08:00:00+00:00\",\n    \"updated_at\": \"2024-01-15T08:00:00+00:00\"\n  },\n  \"request_id\": \"abc123\"\n}"
            },
            {
              "name":   "404 Not Found — Organization does not exist",
              "status": "Not Found",
              "code":   404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"not_found\",\n  \"error\": \"Organization 'b890760f-...' does not exist.\",\n  \"request_id\": \"def456\"\n}"
            }
          ]
        }

      ]
    },

    {
      "name": "2. Employees",
      "description": "Endpoints for managing employee biometric registrations.",
      "item": [

        {
          "name": "POST /employees — Register Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has employee_id', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('employee_id');",
                  "    pm.collectionVariables.set('EMPLOYEE_ID', body.employee_id);",
                  "    console.log('EMPLOYEE_ID set to:', body.employee_id);",
                  "});",
                  "",
                  "pm.test('embedding_dims is 512', function () {",
                  "    pm.expect(pm.response.json().embedding_dims).to.equal(512);",
                  "});",
                  "",
                  "pm.test('Status field is created', function () {",
                  "    pm.expect(pm.response.json().status).to.equal('created');",
                  "});",
                  "",
                  "pm.test('Response time under 5000ms (includes S3 upload)', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method":      "POST",
            "description": "Register a new employee with biometric metadata.\n\nThe face_embedding is a pre-computed floating-point vector from your on-device AI model (FaceNet, ArcFace, etc.).\n\nIf face_photo_b64 is provided, the raw JPEG is decoded and uploaded to the S3 bucket 'wvp-employee-media' at:\n  employees/{organization_id}/{employee_id}/enrollment.jpg\n\nThe face_photo_b64 in this example is a minimal placeholder — replace with a real base64-encoded JPEG.",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key",    "value": "{{API_KEY}}" }
            ],
            "body": {
              "mode": "raw",
