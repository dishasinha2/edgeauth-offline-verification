0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345,\n    0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234,\n    0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678,\n    -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341,\n    0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901,\n    -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678,\n    0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345,\n    -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901,\n    0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456,\n    0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345,\n    0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234,\n    0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678,\n    -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341,\n    0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901,\n    -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678,\n    0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345,\n    -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901,\n    0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456,\n    0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345,\n    0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234,\n    0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678,\n    -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341,\n    0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901,\n    -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678,\n    0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345,\n    -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901,\n    0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456,\n    0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345,\n    0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234,\n    0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678,\n    -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341,\n    0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345, -0.4567, 0.8901,\n    -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901, 0.1234, -0.5678,\n    0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456, 0.5678, 0.2345,\n    -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345, 0.4567, -0.8901,\n    0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234, 0.9876, -0.3456,\n    0.5678, 0.2345, -0.4567, 0.8901, -0.1234, 0.5678, -0.7890, 0.2345,\n    0.4567, -0.8901, 0.1234, -0.5678, 0.7890, -0.2341, 0.6782, -0.1234,\n    0.9876, -0.3456, 0.5678, 0.2345\n  ],\n  \"face_photo_b64\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw":  "{{BASE_URL}}/employees",
              "host": ["{{BASE_URL}}"],
              "path": ["employees"]
            }
          },
          "response": [
            {
              "name":   "201 Created — Employee registered, photo uploaded to S3",
              "status": "Created",
              "code":   201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"created\",\n  \"employee_id\": \"d746f99d-1234-5678-abcd-efgh01234567\",\n  \"organization_id\": \"b890760f-b758-46f1-96bb-516588ad8c21\",\n  \"full_name\": \"Arjun Sharma\",\n  \"embedding_model\": \"arcface_iresnet100_512d\",\n  \"embedding_dims\": 512,\n  \"face_photo_s3_key\": \"employees/b890760f-.../d746f99d-.../enrollment.jpg\",\n  \"face_photo_url\": \"s3://wvp-employee-media/employees/b890760f-.../d746f99d-.../enrollment.jpg\",\n  \"created_at\": \"2024-01-15T08:00:00+00:00\",\n  \"request_id\": \"abc123\"\n}"
